PROJECT_NAME="Personal Expense Tracker API"
MONGODB_URL="mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/expense_db?retryWrites=true&w=majority"
JWT_SECRET_KEY="SuperSecretRandom32ByteHashOrGenerateUsingOpenssl"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT="development"

# ── Email Reminder Settings ──────────────────────────────────────────
# Your Gmail address (the sender account)
SMTP_EMAIL="your-gmail@gmail.com"
# Gmail App Password (16 chars, spaces OK) — get at: myaccount.google.com/apppasswords
SMTP_APP_PASSWORD="xxxx xxxx xxxx xxxx"
# Hour (24h, IST) to fire the daily reminder. 21 = 9 PM IST
REMINDER_HOUR=21
REMINDER_MINUTE=0

